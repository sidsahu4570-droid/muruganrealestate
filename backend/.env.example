PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/realestate
JWT_ACCESS_SECRET=your_super_secret_jwt_access_token_signing_key_here
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_signing_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Comma-separated list of frontend origins allowed to call this API.
# Add the Vercel production URL here when deploying the frontend.
CLIENT_URL=http://localhost:5173,https://your-project.vercel.app

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@realestateplatform.com
